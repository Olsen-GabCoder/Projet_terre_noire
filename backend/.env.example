# =============================================================================
# DÉVELOPPEMENT
# =============================================================================
SECRET_KEY=votre_clé_secrète_longue_et_aléatoire
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données MySQL
DB_NAME=maison_edition
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# CORS — en dev, localhost est autorisé automatiquement
# Cookies JWT : utilisez le MÊME host pour frontend et API (127.0.0.1 partout)
# pour que la session persiste au rechargement

# Admin — création sans shell (python manage.py create_admin_user)
# À mettre dans ton .env avec tes vraies valeurs (ne pas commiter le .env)
CREATE_ADMIN_EMAIL=
CREATE_ADMIN_PASSWORD=

# Email
FRONTEND_URL=http://localhost:5173
DEFAULT_FROM_EMAIL=noreply@terrenoireeditions.com
ADMIN_EMAIL=terrenoireeditions@gmail.com

# SMTP (Gmail : mot de passe d'application sur https://myaccount.google.com/apppasswords)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=terrenoireeditions@gmail.com
EMAIL_HOST_PASSWORD=votre_mot_de_passe_application

# =============================================================================
# PRODUCTION — décommenter et adapter
# =============================================================================
# DEBUG=False
# ALLOWED_HOSTS=votredomaine.com,www.votredomaine.com,api.votredomaine.com
# SECRET_KEY=clé_très_longue_et_aléatoire_différente_de_dev

# CORS — obligatoire en production (DEBUG=False)
# CORS_ALLOWED_ORIGINS=https://votredomaine.com,https://www.votredomaine.com

# URLs production
# FRONTEND_URL=https://votredomaine.com
# LOGO_URL=https://votredomaine.com/images/logo_terre_noire.png

# OAuth — Google (https://console.cloud.google.com/apis/credentials)
# GOOGLE_OAUTH_CLIENT_ID=xxxx.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=xxxx

# OAuth — Facebook (https://developers.facebook.com/apps/)
# FACEBOOK_OAUTH_APP_ID=xxxx
# FACEBOOK_OAUTH_APP_SECRET=xxxx

# Cache Redis (recommandé en production)
# CACHE_URL=redis://localhost:6379/1

# Cloudinary — images (couvertures, auteurs, avatars)
# Créer un compte sur https://cloudinary.com
# CLOUDINARY_CLOUD_NAME=votre_cloud_name
# CLOUDINARY_API_KEY=votre_api_key
# CLOUDINARY_API_SECRET=votre_api_secret
